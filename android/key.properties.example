# Copy to key.properties and fill in your upload keystore details.
# NEVER commit key.properties or *.jks to git.
# Save key.properties as UTF-8 WITHOUT BOM (PowerShell Set-Content -Encoding UTF8 adds BOM and breaks signing).
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=liftoo-upload
storeFile=app/liftoo-upload-keystore.jks
