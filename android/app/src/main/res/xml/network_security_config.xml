<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for local backend testing (phone + PC on same Wi‑Fi). Use HTTPS in production. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
